{
  "$schema": "./agent.config.schema.json",
  "version": "1.0.0",
  "agent": {
    "name": "skillspring-local-agent",
    "max_conversation_history": 20,
    "context_window_tokens": 8192,
    "response_temperature": 0.7,
    "enable_tool_use": true,
    "enable_memory": true,
    "enable_rag": true
  },
  "memory": {
    "short_term": {
      "max_messages": 20,
      "token_budget": 4096
    },
    "long_term": {
      "enabled": true,
      "storage": "sqlite",
      "summarization_trigger": 10,
      "max_stored_summaries": 100
    },
    "working_memory": {
      "enabled": true,
      "max_items": 10,
      "ttl_seconds": 3600
    }
  },
  "rag": {
    "enabled": true,
    "top_k_default": 5,
    "context_chunk_size": 2000,
    "max_context_chunks": 3,
    "include_metadata": true,
    "include_source_links": true
  },
  "tools": {
    "enabled_tools": [
      "search_archives",
      "query_datasets",
      "list_topics",
      "get_conversation",
      "summarize_topic",
      "import_status",
      "run_diagnostic"
    ],
    "tool_timeout_ms": 30000,
    "max_tool_calls_per_turn": 5
  },
  "logging": {
    "level": "info",
    "log_file": "agent_store/agent.log",
    "max_log_size_mb": 10,
    "max_log_files": 5
  }
}
