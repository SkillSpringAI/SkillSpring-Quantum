{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "core/**/*.ts",
    "governance/**/*.json",
    "config/**/*.json",
    "skillspring-quantum-agent/agent/**/*.ts",
    "skillspring-quantum-agent/agent/**/*.json"
  ]
}
