{
  "name": "skillspring-quantum",
  "version": "0.1.0-beta.1",
  "description": "Electron desktop workflow for importing AI exports into readable local archives and structured datasets.",
  "author": "SkillSpring",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "build": "tsc",
    "build:desktop": "tsc --outDir dist-package && npm run renderer:build",
    "start": "node dist/core/pipeline/pipeline.js",
    "dev": "tsx core/pipeline/pipeline.ts",
    "agent": "tsx skillspring-quantum-agent/agent/main.ts",
    "agent:health": "tsx skillspring-quantum-agent/agent/main.ts --health",
    "agent:index": "tsx skillspring-quantum-agent/agent/main.ts --index",
    "agent:server": "tsx skillspring-quantum-agent/agent/main.ts --server",
    "agent:query": "tsx skillspring-quantum-agent/agent/main.ts --query",
    "run:file": "tsx core/pipeline/pipeline.ts",
    "diag:run": "tsx core/diagnostics/diagRunner.ts organized_output",
    "purge:restore": "tsx core/pipeline/restorePurged.ts",
    "folders:merge": "tsx core/pipeline/mergeTopicFolders.ts organized_output",
    "notifications:archive": "tsx core/notifications/readArchiveNotifications.ts organized_output",
    "archive:markdown": "tsx core/notifications/readMarkdownArchive.ts organized_output",
    "batch:run": "tsx core/batch/runBatch.ts",
    "batch:diag": "tsx core/batch/buildBatchDiagnostics.ts organized_output",
    "batch:delta": "tsx core/batch/buildBatchDelta.ts organized_output",
    "imports:history:query": "tsx core/imports/queryImportHistory.ts organized_output",
    "db:promote": "tsx core/db/promoteCurated.ts organized_output",
    "db:review": "tsx core/db/buildReviewQueue.ts organized_output",
    "db:review:decide": "tsx core/db/reviewDecisions.ts",
    "db:list": "tsx core/db/listCollections.ts organized_output",
    "db:read": "tsx core/db/readCollection.ts",
    "governance:list": "tsx core/governance/listRules.ts",
    "governance:read": "tsx core/governance/readRule.ts",
    "governance:write": "tsx core/governance/writeRule.ts",
    "renderer:build": "vite build --config vite.desktop.config.ts",
    "electron:dev": "npm run renderer:build && electron .",
    "package:dir": "npm run build:desktop && electron-builder --dir --publish never",
    "package:win": "npm run build:desktop && electron-builder --win nsis --publish never",
    "test:parser": "tsx tests/parser/chatgpt-parser.test.ts",
    "test:parser:coverage": "tsx tests/parser/chatgpt-parser.test.ts && tsx tests/parser/claude-parser.test.ts && tsx tests/parser/gemini-parser.test.ts && tsx tests/parser/copilot-parser.test.ts && tsx tests/parser/generic-conversation-parser.test.ts && tsx tests/parser/conversation-export-detection.test.ts && tsx tests/parser/gemini-activity-html-parser.test.ts && tsx tests/parser/copilot-activity-csv-parser.test.ts && tsx tests/parser/preflight-copilot-csv.test.ts && tsx tests/parser/import-result-messages.test.ts && tsx tests/parser/dataset-intent.test.ts && tsx tests/parser/dataset-intent-match.test.ts",
    "test:import:intake": "tsx tests/parser/chatgpt-source-intake.test.ts && tsx tests/parser/chatgpt-html-source-intake.test.ts && tsx tests/parser/chatgpt-html-no-conversations-reuse.test.ts && tsx tests/parser/chatgpt-html-import-smoke.test.ts && tsx tests/parser/claude-source-intake.test.ts && tsx tests/parser/copilot-source-intake.test.ts && tsx tests/parser/vendor-package-source-intake.test.ts",
    "test:smoke:vendors": "tsx tests/parser/vendor-import-smoke.test.ts",
    "test:import:history": "tsx tests/parser/import-history-filter.test.ts",
    "test:import:metadata": "tsx tests/parser/import-metadata.test.ts",
    "test:import:retrieval": "tsx tests/parser/import-retrieval-index.test.ts",
    "test:import:shards": "tsx tests/parser/chatgpt-sharded-import-smoke.test.ts && tsx tests/parser/chatgpt-streaming-shard-resume.test.ts",
    "test:imports:pdf": "tsx tests/imports/pdf-text.test.ts",
    "test:imports": "npm run test:import:intake && npm run test:import:history && npm run test:import:metadata && npm run test:import:retrieval && npm run test:import:shards && npm run test:imports:pdf",
    "test:commands": "tsx tests/parser/command-catalog.test.ts",
    "test:agent:paths": "tsx tests/parser/agent-config-path.test.ts",
    "test:agent:models": "tsx tests/parser/model-selection.test.ts",
    "test:assistant": "npm run test:commands && npm run test:agent:paths && npm run test:agent:models",
    "test:retrieval": "tsx tests/parser/retrieval-ranking.test.ts && tsx tests/parser/retrieval-saved-views.test.ts && tsx tests/parser/segment-retrieval-ranking.test.ts",
    "test:segmenter": "tsx tests/pipeline/segmenter.test.ts",
    "test:segmenter:drift": "tsx tests/pipeline/topic-drift-segmenter.test.ts",
    "test:markdown:time": "tsx tests/pipeline/markdown-relative-time.test.ts",
    "test:archive:notifications": "tsx tests/pipeline/archive-notifications.test.ts",
    "test:archive:markdown": "tsx tests/pipeline/markdown-archive-reader.test.ts",
    "test:pipeline:readers": "tsx tests/pipeline/read-dataset-preview.test.ts && tsx tests/pipeline/read-latest-dataset-run.test.ts && tsx tests/pipeline/dataset-source-context.test.ts",
    "test:pipeline:generalization": "tsx tests/pipeline/corpus-agnostic-segmenter.test.ts && tsx tests/pipeline/mixed-generalization-segmenter.test.ts && tsx tests/pipeline/classifier-generalization.test.ts && tsx tests/pipeline/pie-lite-classifier.test.ts && tsx tests/pipeline/segment-summary-label.test.ts",
    "test:pipeline": "npm run test:segmenter && npm run test:segmenter:drift && npm run test:markdown:time && npm run test:archive:notifications && npm run test:archive:markdown && npm run test:topic && npm run test:pipeline:readers && npm run test:pipeline:generalization",
    "test:topic": "tsx tests/pipeline/topic-normalizer.test.ts",
    "test:waste": "tsx tests/governance/waste-classifier.test.ts",
    "test:scorer": "tsx tests/governance/topic-scorer.test.ts",
    "test:filter": "tsx tests/governance/topic-filter.test.ts",
    "test:curation": "tsx tests/governance/curation-rules.test.ts",
    "test:fingerprint": "tsx tests/governance/db-fingerprint.test.ts",
    "test:review": "tsx tests/governance/review-queue-rules.test.ts && tsx tests/governance/topic-segment-identity.test.ts && tsx tests/governance/jsonl-recovery.test.ts",
    "test:review:decision": "tsx tests/governance/review-decision-rules.test.ts",
    "test:paths": "tsx tests/governance/path-utils.test.ts",
    "test:governance:fs": "tsx tests/governance/governance-fs.test.ts && tsx tests/governance/atomic-write.test.ts",
    "test:governance:write": "tsx tests/governance/governance-write-report.test.ts",
    "test:governance:validate": "tsx tests/governance/governance-validate-rule.test.ts",
    "test:governance:redaction": "tsx tests/governance/redaction-runtime.test.ts",
    "test:governance": "npm run test:waste && npm run test:scorer && npm run test:filter && npm run test:curation && npm run test:fingerprint && npm run test:review && npm run test:review:decision && npm run test:paths && npm run test:governance:fs && npm run test:governance:write && npm run test:governance:validate && npm run test:governance:redaction",
    "test:ci": "npm run test:parser:coverage && npm run test:imports && npm run test:smoke:vendors && npm run test:retrieval && npm run test:pipeline && npm run test:assistant && npm run test:governance",
    "test:all": "npm run test:ci"
  },
  "build": {
    "appId": "ai.skillspring.quantum",
    "productName": "SkillSpring Quantum",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json",
      {
        "from": "dist-package",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "ui/app/dist",
        "to": "ui/app/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "asar": true,
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "SkillSpring-Quantum-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.15.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
